{
    "id": "gemini-cli",
    "version": "1.0.0",
    "name": "Gemini CLI",
    "description": "Installs the Gemini CLI and configures global, cross-container OAuth token persistence.",
    "dependsOn": {
        "ghcr.io/devcontainers/features/node:1": {
            "version": "lts"
        },
        "ghcr.io/devcontainers/features/git:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "Google.gemini-cli-vscode-ide-companion" 
            ]
        }
    },
    "mounts": [
        {
            "source": "gemini-cli-oauth-store",
            "target": "/usr/local/gemini-auth",
            "type": "volume"
        }
    ]
}
